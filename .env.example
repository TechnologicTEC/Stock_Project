# Copy this file to .env and fill in your own keys. Never commit .env itself.

# Finnhub — free tier: 60 req/min. Your workhorse data source. finnhub.io
FINNHUB_API_KEY=

# Alpaca Paper Trading — free. Also used here as a backup quote/historical
# source. Create a free paper account at alpaca.markets, then use the
# *paper* API keys (not live-trading keys).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# FRED (Federal Reserve Economic Data) — free, official. fred.stlouisfed.org
FRED_API_KEY=

# SEC EDGAR requires a real identifying User-Agent (not an app name) on every
# request, or it will reject you. Use your actual name + email.
# https://www.sec.gov/os/webmaster-faq#developers
EDGAR_USER_AGENT="Your Name your.email@example.com"

# Financial Modeling Prep — free tier: 250 req/day. Fills fundamentals gaps
# Finnhub's free tier doesn't cover. financialmodelingprep.com
FMP_API_KEY=

# Alpha Vantage — free tier: 25 req/day. Use sparingly (see blueprint
# Section 2) — only for things Finnhub doesn't offer free, like news
# sentiment scoring or certain macro series.
ALPHA_VANTAGE_API_KEY=

# Hugging Face token — OPTIONAL. FinBERT (Phase 4 sentiment) is a public model
# and downloads fine without this, but anonymous Hub requests get lower rate
# limits + slower downloads (and log a "set a HF_TOKEN" warning each load). A
# free *read* token from huggingface.co/settings/tokens silences it and helps
# on deploy (HF Spaces). huggingface_hub reads this env var automatically.
HF_TOKEN=

# Google Gemini — OPTIONAL, free tier. Powers the Assistant page's free-form
# chat mode; Gemini answers by calling the app's own chat tools. Without it, the
# Assistant falls back to a deterministic template responder — nothing breaks.
# Get a free key at aistudio.google.com (no billing required).
GEMINI_API_KEY=
# Optional: which model the chat uses. Defaults to gemini-2.5-flash.
# CHAT_LLM_MODEL=gemini-2.5-flash

# Multi-user roles (see multi_user_plan.md). Comma-separated emails granted
# owner/friend access; anyone signing in who isn't listed is a guest. Requires
# Google OIDC configured in .streamlit/secrets.toml to actually log people in.
OWNER_EMAILS=
FRIEND_EMAILS=
# Force the login prompt even without OIDC (mostly for testing). Normally the
# presence of the [auth] block in secrets.toml is what enables login.
# REQUIRE_LOGIN=
# Local dev only: act as this email instead of the bootstrap owner (to simulate
# a friend/guest without signing in). Leave unset in production.
# DEV_LOGIN_EMAIL=

# Master key that encrypts every user's stored API keys at rest (Fernet). Each
# user enters their own Finnhub/Alpaca/Gemini keys on the Settings page; they're
# encrypted with THIS key before touching the database, so the DB never holds a
# usable key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep it in the host's secret store (Streamlit/HF Spaces secrets), NEVER in the
# database or git. If unset, a throwaway per-process key is used — fine for local
# dev, but stored keys become unreadable after a restart. Rotating this key makes
# all previously-stored user keys unreadable (users must re-enter them).
APP_ENCRYPTION_KEY=

# Optional: override the default SQLite file location, or point at Postgres
# later if you move to a shared DB with a collaborator (see Section 13).
# DATABASE_URL=sqlite:///db/investment.db

GOOGLE_CLOUD_PROJECT=your-project-id