# Copy this file to .env and fill in your own keys.
# .env is gitignored - never commit real keys, and don't share one key with
# your collaborator (it splits an already-tight rate limit between you).

# Finnhub - finnhub.io (free signup)
FINNHUB_API_KEY=your_finnhub_key_here

# Financial Modeling Prep - financialmodelingprep.com (free signup)
FMP_API_KEY=your_fmp_key_here

# Alpha Vantage - alphavantage.co (free signup, but only 25 requests/day - use sparingly)
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# Alpaca - alpaca.markets (free paper trading account)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# FRED - fred.stlouisfed.org (free signup)
FRED_API_KEY=your_fred_key_here

# Reddit / PRAW - NOT NEEDED for the default build.
# Dropped per Reddit's June 2026 Responsible Builder Policy, which requires
# written approval for scraping/ML use of Reddit data even non-commercially.
# Only fill these in if you've gotten approved access and uncomment praw in
# requirements.txt.
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=investment-platform-personal-use
