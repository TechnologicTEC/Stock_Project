# Copy this file to .streamlit/secrets.toml and fill in real values to enable
# "Sign in with Google". The real secrets.toml is gitignored — never commit it.
#
# One-time Google setup:
#   1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client
#      ID → Application type: "Web application".
#   2. Add an Authorized redirect URI:
#        local:  http://localhost:8501/oauth2callback
#        deploy: https://<your-space-or-domain>/oauth2callback
#   3. Copy the Client ID and Client secret below.
#   4. Configure the OAuth consent screen and add your + your friends' emails as
#      test users (or publish it).
#
# Presence of this [auth] section is what turns login ON. With it, anonymous
# visitors are prompted to sign in (or continue as guest). Without it (no
# secrets.toml), the app runs in local single-user mode as the bootstrap owner.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-long-random-string"       # e.g. python -c "import secrets;print(secrets.token_hex(32))"
client_id = "your-google-oauth-client-id.apps.googleusercontent.com"
client_secret = "your-google-oauth-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Roles are assigned by email (see .env's OWNER_EMAILS / FRIEND_EMAILS). Anyone
# who signs in but isn't listed is treated as a guest.
